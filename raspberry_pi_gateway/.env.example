FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.asia-southeast1.firebasedatabase.app/
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# Bind to loopback by default. Set to 0.0.0.0 only if the gateway must be
# reachable from the ESP32 on the LAN, and keep the port firewalled.
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Never enable debug in production. The Werkzeug debugger allows remote code
# execution if exposed.
FLASK_DEBUG=false

# Shared secret required in the X-API-Key header to POST /api/hive-data.
# Leave empty to disable auth (not recommended). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Comma-separated list of origins allowed to call the API from a browser.
CORS_ALLOWED_ORIGINS=http://localhost:5000

# Maximum accepted request body size in bytes.
MAX_CONTENT_LENGTH_BYTES=65536
